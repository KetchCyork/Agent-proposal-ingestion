# Where your Obsidian vault lives (the store of record).
VAULT_PATH=

# Local embeddings via Ollama (free, private). Pull once: ollama pull nomic-embed-text
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# Where the LanceDB index is stored (defaults to ~/.agent-memory-mesh/memory.lancedb)
MEMORY_DB_PATH=

# Service binding. Default 127.0.0.1 = loopback only (safe).
# To share across your Tailscale mesh, set this to the host's tailnet name, e.g.
#   MEMORY_HOST=mac-2026.tailnet-name.ts.net
MEMORY_HOST=127.0.0.1
MEMORY_PORT=8377

# Shared secret required on every HTTP request (X-Api-Key). Strongly recommended
# whenever MEMORY_HOST is not loopback.
MEMORY_API_KEY=
