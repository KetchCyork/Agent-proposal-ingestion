  "type": "module",
  "scripts": {
    "index": "tsx src/cli/index.ts",
    "serve": "tsx src/cli/serve.ts",
    "serve:mcp": "tsx src/cli/serve.ts --mcp",
    "typecheck": "tsc --noEmit",
    "ingest": "tsx src/cli/ingest.ts",
    "learn-style": "tsx src/cli/learn-style.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@lancedb/lancedb": "^0.24.0",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "dotenv": "^16.4.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.0",
    "mammoth": "^1.8.0",
    "unpdf": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
